# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# PyPI configuration file
.pypirc

.vscode

# ignore large model files - download from gdrive
*.tar

# ignore locally saved audio
*.mp3
*.webm

# ignore below since it gets updated on every local run
uploads/skin_lesion_output/segmentation_plot.png

# ============================================================
#  Project-specific ignores
# ============================================================

# Secrets — NEVER commit
.env
.env.*
!.env.example

# OS / editor clutter
.DS_Store
**/.DS_Store

# Generated RAG artifacts (regenerated by ingestion — do not commit)
data/qdrant_db/
data/docs_db/
data/parsed_docs/
data/raw_extras/

# User uploads & generated outputs (keep the placeholder .gitkeep files)
uploads/backend/*
uploads/frontend/*
uploads/speech/*
uploads/skin_lesion_output/*
!uploads/**/.gitkeep

# Local HuggingFace model cache (if HF_HOME points inside the project)
model_cache/

# Large demo videos (bloat the repo; not referenced by README)
assets/*.mp4

# Claude Code local settings (machine-specific)
.claude/