# Secrets — never bake into the image
.env
.env.*
!.env.example

# Git & CI
.git
.github
.gitignore

# Python caches
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# OS / editor
.DS_Store
**/.DS_Store
.claude/

# Local model cache (if HF_HOME points inside the project)
model_cache/

# Generated / heavy RAG artifacts (regenerated by ingestion at runtime)
data/parsed_docs/
data/raw_extras/
data/qdrant_db/
data/docs_db/

# User uploads & generated outputs
uploads/backend/*
uploads/frontend/*
uploads/speech/*
uploads/skin_lesion_output/*
!uploads/**/.gitkeep

# Large demo videos
assets/*.mp4

# Docs that don't belong in the image
*.md
!README.md
